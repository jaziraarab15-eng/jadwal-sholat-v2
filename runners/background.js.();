addEventListener('checkPrayer', async (resolve, reject) => {
  try {
    console.log('Background Runner aktif');

    const response = await fetch('https://api.aladhan.com/v1/timingsByCity?city=Jakarta&country=Indonesia&method=11');
    const data = await response.json();

    console.log('Jadwal berhasil diambil');

    resolve(data);
  } catch (err) {
    console.error(err);
    reject(err);
  }
});
